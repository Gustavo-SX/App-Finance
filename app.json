{
  "expo": {
    "name": "finan-app",
    "slug": "finan-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./image/logo.png",
    "scheme": "finanapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gustavosx.finanapp"
    },
    "android": {
      "adaptiveIcon": {
      "foregroundImage": "./assets/icon.png",
      "backgroundColor": "#E6F4FE"
},
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.gustavosx.finanapp"
    },
    "web": {
      "output": "single",
      "favicon": "./image/logo.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./image/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "22d8a29c-e6e3-4bc8-a2d4-6982e1c4783f"
      }
    }
  }
}
